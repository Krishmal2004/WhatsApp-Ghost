{
  "manifest_version": 3,
  "name": "WA Ghost Mode - Always Active",
  "version": "2.1",
  "description": "Persistent WhatsApp read receipt blocker",
  "permissions": [
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ]
}